# ─── Azure App Registration ───────────────────────────────────────────────────
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-app-client-secret
AZURE_TENANT_ID=your-tenant-id
# For multi-tenant: use "common" or "organizations"
# AZURE_TENANT_ID=common

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-min-64-chars
JWT_EXPIRES_IN=8h

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ca_guardian
DB_USER=ca_guardian_user
DB_PASSWORD=your-db-password

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost:5173
# API base for redirect URI
API_BASE_URL=http://localhost:3001

# ─── Email Notifications ──────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=ca-guardian@yourdomain.com
SMTP_PASS=your-smtp-password
NOTIFY_FROM=ca-guardian@yourdomain.com
# Comma-separated admin emails
ADMIN_EMAILS=admin@yourdomain.com

# ─── Polling ──────────────────────────────────────────────────────────────────
# How often to poll Graph API for changes (minutes)
POLL_INTERVAL_MINUTES=5

# ─── Security ─────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
SESSION_SECRET=another-long-random-secret
